{
  "expo": {
    "name": "Danhausa",
    "slug": "danhausa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/danhausa-icon.png",
    "scheme": "danhausa",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.danhausa.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.danhausa.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/danhausa-icon.png",
        "backgroundColor": "#ffffff"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "danhausa"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/danhausa.png"
    },
    "plugins": ["expo-router", "expo-font", "expo-web-browser"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
